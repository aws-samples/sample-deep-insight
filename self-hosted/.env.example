# AWS OpenTelemetry Configuration
OTEL_PYTHON_DISTRO=aws_distro
OTEL_PYTHON_CONFIGURATOR=aws_configurator
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_LOGS_HEADERS=x-aws-log-group=bedrock-agentcore-observability,x-aws-log-stream=custom-spans,x-aws-metric-namespace=AgentCore
OTEL_RESOURCE_ATTRIBUTES=service.name=deep-insight-runtime # OTEL_RESOURCE_ATTRIBUTES=service.name ==> (cloudwatch) GenAI Observability에서 Agent Name에 적용
AGENT_OBSERVABILITY_ENABLED=true

# AWS Configuration
AWS_REGION=us-west-2
AWS_DEFAULT_REGION=us-west-2
AWS_ACCOUNT_ID=your-account-id

# ============================================================
# Agent - Workflow Configuration
# ============================================================
# Maximum number of plan revisions allowed before auto-approval
MAX_PLAN_REVISIONS=10

# ============================================================
# Agent - Bedrock Model Configuration
# ============================================================
DEFAULT_MODEL_ID=global.anthropic.claude-sonnet-4-6
COORDINATOR_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
PLANNER_MODEL_ID=global.anthropic.claude-opus-4-8
SUPERVISOR_MODEL_ID=global.anthropic.claude-sonnet-4-6
CODER_MODEL_ID=global.anthropic.claude-sonnet-4-6
VALIDATOR_MODEL_ID=global.anthropic.claude-sonnet-4-6
REPORTER_MODEL_ID=global.anthropic.claude-sonnet-4-6
AUDITOR_MODEL_ID=global.anthropic.claude-sonnet-4-6
TRACKER_MODEL_ID=global.anthropic.claude-sonnet-4-6

# Web Q&A chatbot (deep-insight-web/chat_agent.py). Used for natural-language
# → DuckDB SQL conversion + chart generation.
CHAT_MODEL_ID=global.anthropic.claude-sonnet-4-6

# Web Q&A: enable Bedrock prompt caching (~90% input-token savings on repeat
# turns). Set to "0" to disable for debugging.
ENABLE_PROMPT_CACHE=1

# Web Q&A: SessionManager bounds. Each session pins ~2× CSV size in RAM.
# Defaults tuned for a 2 GB Fargate task with ≤ 5 concurrent users.
CHAT_SESSION_MAX=20
CHAT_SESSION_IDLE_TTL_SEC=1800